# Copy this file to .env and fill in your values
# Never commit .env to git

# IONOS Inference API (for the LLM chat)
IONOS_API_TOKEN=your_inference_api_token_here

# IONOS Cloud API (for server management)
IONOS_CLOUD_USERNAME=your_ionos_email@example.com
IONOS_CLOUD_PASSWORD=your_ionos_password_here

# Model config
MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct
ENDPOINT=https://openai.inference.de-txl.ionos.com/v1/chat/completions
